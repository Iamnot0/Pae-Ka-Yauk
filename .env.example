# ========================================
# Pae Ka Yauk POS — environment template
# Copy to .env and fill in real values
# ========================================

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Tenant resolution ---
# Phase 1: hardcoded single tenant. Phase 2 will switch to URL-based.
TENANT_SLUG="pae-ka-yauk"

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- Printer (Epson TM · raw ESC/POS over TCP 9100 / "JetDirect") ---
# Factory-default IP for an un-configured TM-series printer is
# 192.168.192.168. Put it on your shop LAN and update HOST accordingly.
PRINTER_HOST="192.168.192.168"
PRINTER_PORT="9100"

# --- Email (shift-close PDF delivery) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
OWNER_EMAIL=""

# --- Storage (image uploads) ---
# "local" → public/uploads/ (dev + Hostinger VPS)
# "vercel-blob" → Vercel Blob (Vercel deploy; needs BLOB_READ_WRITE_TOKEN)
STORAGE_PROVIDER="local"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"  # auto-set by Vercel

# --- Feature flags ---
NEXT_PUBLIC_SYNC_ENGINE="electric"  # "electric" | "powersync" | "dexie-only"
NEXT_PUBLIC_USE_MYANMAR_NUMERALS="false"  # "true" shows ၂,၅၀၀; "false" shows 2,500
